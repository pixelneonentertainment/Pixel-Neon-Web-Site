# Pixel Neon Entertainment — Ortam Değişkenleri
# Bu dosyayı .env olarak kaydet ve GİT'E EKLEME (.gitignore'a ekle!)
# server.js veya proxy.py ile aynı klasöre koy.

# Google Gemini API anahtarı (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=AIzaSy_BURAYA_GERCEK_ANAHTARI_YAPISTIR

# Anthropic API anahtarı (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=sk-ant-BURAYA_GERCEK_ANAHTARI_YAPISTIR

# Proxy'nin dinleyeceği port
PORT=3001

# CORS: sadece bu origin'den gelen isteklere izin ver
ALLOWED_ORIGIN=https://pixelneon.com.tr
